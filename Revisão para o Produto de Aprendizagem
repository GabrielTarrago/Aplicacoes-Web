import { useState } from 'react'

function Cadastro() {
  const [form, setForm] = useState({
    nome: '',
    cpf: '',
    telefone: '',
    rg: '',
    endereco: ''
  })

  function handleChange(e) {
    setForm({
      ...form,
      [e.target.name]: e.target.value
    })
  }

  function cadastrar(e) {
    e.preventDefault()
    alert('Cadastro realizado com sucesso!')
    console.log(form)
  }

  return (
    <div>
      <h1>Cadastro</h1>

      <form onSubmit={cadastrar}>
        <div>
          <label>Nome:</label><br />
          <input
            type="text"
            name="nome"
            value={form.nome}
            onChange={handleChange}
          />
        </div>

        <div>
          <label>CPF:</label><br />
          <input
            type="text"
            name="cpf"
            value={form.cpf}
            onChange={handleChange}
          />
        </div>

        <div>
          <label>Telefone:</label><br />
          <input
            type="text"
            name="telefone"
            value={form.telefone}
            onChange={handleChange}
          />
        </div>

        <div>
          <label>RG:</label><br />
          <input
            type="text"
            name="rg"
            value={form.rg}
            onChange={handleChange}
          />
        </div>

        <div>
          <label>Endereço:</label><br />
          <input
            type="text"
            name="endereco"
            value={form.endereco}
            onChange={handleChange}
          />
        </div>

        <br />

        <button type="submit">
          Cadastrar
        </button>
      </form>
    </div>
  )
}

export default Cadastro
