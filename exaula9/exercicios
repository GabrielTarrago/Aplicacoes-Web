HTML
<input type="number" id="num" min="1" max="10">
<button onclick="tabuada()">Mostrar</button>

<p id="tab"></p>
JS
function tabuada() {
    let num = Number(document.getElementById("num").value);
    let texto = "";

    for (let i = 1; i <= 10; i++) {
        texto += num + " x " + i + " = " + (num * i) + "<br>";
    }

    document.getElementById("tab").innerHTML = texto;
}
